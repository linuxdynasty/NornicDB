#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_go_files=()
while IFS= read -r -d '' file; do
    staged_go_files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -z -- '*.go')

if [ "${#staged_go_files[@]}" -eq 0 ]; then
    exit 0
fi

# Conflict-safe mode:
# do not stash/pop. If a staged Go file also has unstaged edits, refuse and ask
# the user to split/stage cleanly first. This avoids stash-pop merge conflicts.
conflicted_files=()
for file in "${staged_go_files[@]}"; do
    if ! git diff --quiet -- "$file"; then
        conflicted_files+=("$file")
    fi
done

if [ "${#conflicted_files[@]}" -gt 0 ]; then
    echo "pre-commit: unstaged edits detected in staged Go files." >&2
    echo "pre-commit: refusing to auto-format to avoid merge conflicts." >&2
    printf '  %s\n' "${conflicted_files[@]}" >&2
    echo "pre-commit: stage/commit those edits first (or stash manually), then retry." >&2
    exit 1
fi

gofmt -w -s "${staged_go_files[@]}"
git add -- "${staged_go_files[@]}"
